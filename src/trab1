    public static void menuDisciplina(Disciplina[] disci, Aluno[] alunos) {
        int opcao;
        do {
            System.out.println("\nMenu disciplina");
            System.out.println("1 - Inserir Disciplina");
            System.out.println("2 - Listar Disciplinas");
            System.out.println("3 - Excluir Disciplinas");
            System.out.println("4 - Editar disciplinas");
            System.out.println("0 - Voltar");
            opcao = sc.nextInt();
            switch (opcao) {
                case 1:
                    scannerdisc(disci);
                    break;
                case 2:
                    listardisc(disci);
                    break;
                case 3:
                    excluirdisc(disci, alunos);
                    break;
                case 4:
                    editardisci(disci);
                    break;
                default:
                    if (opcao != 0)
                        System.out.println("Opçao invalida");
            }
        } while (opcao != 0);
    }

