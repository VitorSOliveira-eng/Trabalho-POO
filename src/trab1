    // funcao para alterar dados de um aluno existente
    public static void alterarAluno(Aluno[] alunos) {
        System.out.print("Digite o código do aluno que deseja alterar: ");
        int cod = sc.nextInt();
        int encontrada = 0;

        for (int i = 0; i < alunos.length; i++) {
            if (alunos[i] != null && alunos[i].codigo == cod) {
                sc.nextLine();
                System.out.print("Novo nome: ");
                String novoNome = sc.nextLine();

                // verifica se novo nome ja existe
                boolean jaExiste = false;
                for (int j = 0; j < alunos.length; j++) {
                    if (alunos[j] != null && alunos[j].codigo != cod && alunos[j].nome.equalsIgnoreCase(novoNome)) {
                        jaExiste = true;
                        break;
                    }
                }

                if (jaExiste) {
                    System.out.println("Erro: Já existe outro aluno com esse nome.");
                } else {
                    alunos[i].nome = novoNome;
                    System.out.print("Novo endereço: ");
                    alunos[i].endereco = sc.nextLine();
                    System.out.println("Dados alterados com sucesso!");
                }
                encontrada = 1;
                break;
            }
        }
        if (encontrada == 0)
            System.out.println("Aluno não encontrado.");
    }

   
   
   
    // excluir aluno 
    public static void excluirAluno(Aluno[] alunos) {
        System.out.print("Digite o código do aluno para ser excluido: ");
        int codigo = sc.nextInt();
        int encontrada = 0;

        for (int i = 0; i < alunos.length; i++) {
            if (alunos[i] != null && alunos[i].codigo == codigo) {
                // desloca
                for (int j = i; j < alunos.length - 1; j++) {
                    alunos[j] = alunos[j + 1];
                }
                alunos[alunos.length - 1] = null;
                System.out.println("Aluno excluido com sucesso.");
                encontrada = 1;
                break;
            }
        }
        if (encontrada == 0)
            System.out.println("Aluno não encontrado.");
    }

    
    
    
    
    public static void scannerAluno(Aluno[] alunos) {
        sc.nextLine();
        System.out.print("Nome do Aluno: ");
        String nome = sc.nextLine();

        // Não permitir nomes repetidos
        for (int i = 0; i < alunos.length; i++) {
            if (alunos[i] != null && alunos[i].nome.equalsIgnoreCase(nome)) {
                System.out.println("ERRO: Já existe um aluno com este nome!");
                return;
            }
        }

        System.out.print("Endereço: ");
        String endereco = sc.nextLine();

        inserirAlunoNoVetor(alunos, nome, endereco);
        System.out.println("Aluno cadastrado com sucesso!");
    }

   
   
   
    public static void inserirAlunoNoVetor(Aluno[] alunos, String nome, String endereco) {
        for (int i = 0; i < alunos.length; i++) {
            if (alunos[i] == null) {
                alunos[i] = new Aluno();
                alunos[i].codigo = codigoaluno++;
                alunos[i].nome = nome;
                alunos[i].endereco = endereco;
                break;
            }
        }
    }

    
    
    
    
    public static void funcionalidadeMatricular(Aluno[] alunos, Disciplina[] disci) {
        System.out.print("Digite o código do Aluno: ");
        int codA = sc.nextInt();
        System.out.print("Digite o código da Disciplina: ");
        int codD = sc.nextInt();

        Aluno alu = null;
        // Busca o aluno
        for (int i = 0; i < alunos.length; i++) {
            if (alunos[i] != null && alunos[i].codigo == codA) {
                alu = alunos[i];
                break; // Encontrou
            }
        }

        Disciplina dsc = null;
        // Busca a disciplina
        for (int i = 0; i < disci.length; i++) {
            if (disci[i] != null && disci[i].cd == codD) {
                dsc = disci[i];
                break; // Encontrou
            }
        }

        if (alu != null && dsc != null) {
            if (alu.qtdDisciplinas < 10) {

                System.out.print("Digite a nota final: ");
                double nota = sc.nextDouble();

                alu.disciplinasMatriculadas[alu.qtdDisciplinas] = dsc;
                alu.notas[alu.qtdDisciplinas] = nota;
                alu.qtdDisciplinas++;

                // Recalcula média
                double soma = 0;
                for (int i = 0; i < alu.qtdDisciplinas; i++)
                    soma += alu.notas[i];
                alu.media = soma / alu.qtdDisciplinas;

                System.out.println("Matrícula realizada!");
            } else {
                System.out.println("Limite de 10 disciplinas atingido!");
            }
        } else {
            System.out.println("Aluno ou Disciplina não encontrados.");
        }
    }

    
    
    
    
    public static void listarAlunos(Aluno[] alunos, int tipo) {
        // Não altera o vetor
        Aluno[] copia = new Aluno[alunos.length];
        int total = 0;
        for (int i = 0; i < alunos.length; i++) {
            if (alunos[i] != null)
                copia[total++] = alunos[i];
        }
    
        if (tipo == 2) { // (Bubble Sort) 
            for (int i = 0; i < total - 1; i++) {
                for (int j = 0; j < total - 1 - i; j++) {
                    if (copia[j].media < copia[j + 1].media) {
                        Aluno temp = copia[j];
                        copia[j] = copia[j + 1];
                        copia[j + 1] = temp;
                    }
                }
            }
        }
    
        
        
    
        String linha = ""; // laço para o número de - na tabela
        for (int k = 0; k < (tamtabela * 5); k++) {
            linha += "-";
        }
    
        System.out.println("\n" + linha);
        
        
        System.out.printf(
                "%-" + tamtabela + "s %-" + tamtabela + "s %-" + tamtabela + "s %-" + tamtabela + "s %-" + tamtabela
                        + "s\n",
                "CÓDIGO", "NOME", "ENDEREÇO", "DISCIPLINAS", "MÉDIA");
    
        for (int i = 0; i < total; i++) {
            String siglas = "";
            
            //
            for (int j = 0; j < copia[i].qtdDisciplinas; j++) {
                siglas += copia[i].disciplinasMatriculadas[j].sigla;
                
                if (j < copia[i].qtdDisciplinas - 1) {
                    siglas += ", ";
                }
            }
    
            // 
            System.out.printf(
                    "%-" + tamtabela + "d %-" + tamtabela + "s %-" + tamtabela + "s %-" + tamtabela + "s %-" + tamtabela
                            + ".1f\n",
                    copia[i].codigo, copia[i].nome, copia[i].endereco, siglas, copia[i].media);
        }
    }

    
    
    
