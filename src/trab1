    /*
     * metodo para inserir os dados das disciplinas
     * pegos pelo scanner da scannerdisc
     */
     
    public static void inserir(Disciplina[] disci, String nome, String sigla, String ano, String professor) {
        for (int i = 0; i < disci.length; i++) {
            if (disci[i] == null) {
                disci[i] = new Disciplina();
                disci[i].cd = codigodisci++;
                disci[i].nome = nome;
                disci[i].sigla = sigla;
                disci[i].ano = ano;
                disci[i].nomeprofessor = professor;
                break;
            }
        }
    }

    
     
