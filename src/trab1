    // excluir disciplinas
    public static void excluirdisc(Disciplina[] disci, Aluno[] alunos) {
        int verifica = 0;
        int codigo;
        int encontrada = 0;
        System.out.println("Digite o código da disciplina para ser excluida");
        codigo = sc.nextInt();
        // verifica se tem aluno matriculado na disciplina
        for (int i = 0; i < alunos.length; i++) {
            if (alunos[i] != null) {
                for (int j = 0; j < alunos[i].qtdDisciplinas; j++) {
                    if (alunos[i].disciplinasMatriculadas[j].cd == codigo
                            && alunos[i].disciplinasMatriculadas[j] != null) {

                        verifica = 1;
                        break;
                    }
                }
            }
            /*
             * impede de percorrer todas as posicoes caso ja
             * tenha encontrado um aluno matriculado
             */
            if (verifica == 1) {
                break;
            }
        }
        /*
         * exclui a disci "empurrando" ela pro final do vetor
         * e transformando em null
         */
        for (int i = 0; i < disci.length; i++) {
            if (disci[i] != null && disci[i].cd == codigo && verifica != 1) {

                for (int j = i; j < disci.length - 1; j++) {
                    disci[j] = disci[j + 1];
                }
                disci[disci.length - 1] = null;
                System.out.println("Disciplina excluida");
                encontrada = 1;
                break;
            }
        }
        // caso digite um codigo nao valido ou uma disc com aluno matriculado
        if (verifica == 1) {
            System.out.println("Disciplina com aluno matriculado");
        } else if (encontrada != 1) {
            System.out.println("Disciplina nao encontrada");
        }

    }

    
    
    
    
    
